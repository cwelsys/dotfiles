#!/usr/bin/env bash

set -euo pipefail

command -v gpgconf >/dev/null 2>&1 || exit 0

headless={{ .headless }}

# systemd unit name -> gpgconf --list-dirs key
declare -A units=(
  [gpg-agent.socket]=agent-socket
  [gpg-agent-extra.socket]=agent-extra-socket
  [gpg-agent-ssh.socket]=agent-ssh-socket
  [gpg-agent-browser.socket]=agent-browser-socket
  [dirmngr.socket]=dirmngr-socket
  [keyboxd.socket]=keyboxd-socket
)

agent_units=(gpg-agent.socket gpg-agent-extra.socket gpg-agent-ssh.socket gpg-agent-browser.socket)

unit_dir="${XDG_CONFIG_HOME:-$HOME/.config}/systemd/user"
changed=0

for unit in "${!units[@]}"; do
  path="$(gpgconf --list-dirs "${units[$unit]}" 2>/dev/null)" || continue
  [[ -n "$path" ]] || continue
  d="$unit_dir/${unit}.d"
  want="$(printf '[Socket]\nListenStream=\nListenStream=%s\n' "$path")"
  if [[ "$(cat "$d/override.conf" 2>/dev/null || true)" != "$want" ]]; then
    mkdir -p "$d"
    printf '%s\n' "$want" >"$d/override.conf"
    changed=1
  fi
done

for unit in "${agent_units[@]}"; do
  state="$(systemctl --user is-enabled "$unit" 2>/dev/null || true)"
  if [[ "$headless" == "true" ]]; then
    if [[ "$state" != "masked" ]]; then
      systemctl --user stop "$unit" 2>/dev/null || true
      systemctl --user mask "$unit" >/dev/null 2>&1 || true
      changed=1
    fi
  elif [[ "$state" == "masked" ]]; then
    systemctl --user unmask "$unit" >/dev/null 2>&1 || true
    changed=1
  fi
done

if ((changed)) && systemctl --user show >/dev/null 2>&1; then
  systemctl --user daemon-reload
  gpgconf --kill all 2>/dev/null || true
  if [[ "$headless" == "true" ]]; then
    restart=(keyboxd.socket dirmngr.socket)
  else
    restart=("${!units[@]}")
  fi
  systemctl --user restart "${restart[@]}" 2>/dev/null || true
fi
