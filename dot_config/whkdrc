.shell powershell

# reload whkd / configuration
alt + o                 : taskkill /f /im whkd.exe; Start-Process whkd -windowStyle hidden # if shell is pwsh / powershell
alt + shift + o         : komorebic reload-configuration

# App shortcuts - these require shell to be pwsh / powershell
# The apps will be focused if open, or launched if not open
# alt + f                 : if ($wshell.AppActivate('Firefox') -eq $False) { start firefox }
# alt + b                 : if ($wshell.AppActivate('Chrome') -eq $False) { start chrome }

# toggle FFM
# VK_HOME													: komorebic toggle-focus-follows-mouse --implementation komorebi

# min/max/close/misc
alt + q                 				: komorebic close

# win + w 							 					: wt

alt + m                 				: komorebic minimize
alt + shift + m				 					: komorebic maximize
win + shift + m				 					: komorebic maximize

alt + escape						 				: komorebic unstack
win + q							 				    : komorebic unstack
win + escape						 				: komorebic unstack

win + m								 				  : komorebic toggle-monocle


# f13                           	: komorebic cycle-focus previous

rctrl + left								: komorebic move left
rctrl + down								: komorebic move down
rctrl + up									: komorebic move up
rctrl + right								: komorebic move right

# move

alt + left         					: komorebic move left
alt + down         					: komorebic move down
alt + up           					: komorebic move up
alt + right        					: komorebic move right

f13 + a        							: komorebic move left
f13 + s      								: komorebic move down
f13 + w         						: komorebic move up
f13 + d      								: komorebic move right
f13 + q											: komorebic cycle-focus previous
f13 + e											: komorebic cycle-focus next
f13 + x											: komorebic unstack
f13 + f											: komorebic toggle-float
f13 + m											: komorebic toggle-monocle
f13 + r											: komorebic retile
f13 + p											: komorebic toggle-pause
f13 + return							  : komorebic promote

# promote
win + return			 					: komorebic promote
alt + return       					: komorebic promote

# Uncommented and activated alt + shift + arrow keys for stacking
alt + shift + left              : komorebic stack left
alt + shift + down              : komorebic stack down
alt + shift + up                : komorebic stack up
alt + shift + right             : komorebic stack right


# resize
alt + oem_plus          				: komorebic resize-axis horizontal increase
alt + oem_minus         				: komorebic resize-axis horizontal decrease
alt + shift + oem_plus  				: komorebic resize-axis vertical increase
alt + shift + oem_minus 				: komorebic resize-axis vertical decrease

# manipulate
alt + f                 				: komorebic toggle-float
alt + shift + f         				: komorebic toggle-monocle

# komorebi options
alt + r         								: komorebic retile
alt + p                 				: komorebic toggle-pause

# layouts
alt + x                 				: komorebic flip-layout horizontal
alt + y                 				: komorebic flip-layout vertical

# workspaces
alt + 1                 : komorebic focus-workspace 0
alt + 2                 : komorebic focus-workspace 1
alt + 3                 : komorebic focus-workspace 2
# alt + 4                 : komorebic focus-workspace 3
# alt + 5                 : komorebic focus-workspace 4
# alt + 6                 : komorebic focus-workspace 5
# alt + 7                 : komorebic focus-workspace 6
# alt + 8                 : komorebic focus-workspace 7

# Move across workspaces
alt + shift + 1         : komorebic move-to-workspace 0
alt + shift + 2         : komorebic move-to-workspace 1
alt + shift + 3         : komorebic move-to-workspace 2
# alt + shift + 4         : komorebic move-to-workspace 3
# alt + shift + 5         : komorebic move-to-workspace 4
# alt + shift + 6         : komorebic move-to-workspace 5
# alt + shift + 7         : komorebic move-to-workspace 6
# alt + shift + 8         : komorebic move-to-workspace 7
