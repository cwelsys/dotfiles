# PowerShell Profile with Bitwarden Integration

# Import modules
Import-Module posh-git
Import-Module PSReadLine
Import-Module Terminal-Icons
Import-Module PSFzf

# PSReadLine configuration
Set-PSReadLineOption -PredictionSource History
Set-PSReadLineOption -PredictionViewStyle ListView
Set-PSReadLineOption -EditMode Emacs
Set-PSReadLineOption -BellStyle None
Set-PSReadLineKeyHandler -Chord 'Ctrl+d' -Function DeleteChar
Set-PSReadLineKeyHandler -Key Tab -Function Complete

# Set up Starship prompt
Invoke-Expression (&starship init powershell)

# Set up zoxide
Invoke-Expression (& {
    $hook = if ($PSVersionTable.PSVersion.Major -lt 6) { 'prompt' } else { 'pwd' }
    (zoxide init --hook $hook powershell | Out-String)
})

# Set up fzf
Set-PsFzfOption -PSReadlineChordProvider 'Ctrl+t' -PSReadlineChordReverseHistory 'Ctrl+r'

# Aliases
Set-Alias -Name vim -Value nvim
Set-Alias -Name g -Value git
Set-Alias -Name ll -Value ls
Set-Alias -Name grep -Value Select-String
Set-Alias -Name cat -Value bat
Set-Alias -Name touch -Value New-Item
Set-Alias -Name which -Value Get-Command

# Functions
function .. { Set-Location .. }
function ... { Set-Location ../.. }
function .... { Set-Location ../../.. }
function cd.. { Set-Location .. }

# Git aliases
function gs { git status }
function ga { git add $args }
function gc { git commit -m $args }
function gp { git push }
function gl { git pull }
function gd { git diff $args }
function gb { git branch $args }
function gco { git checkout $args }
function glog { git log --oneline --graph --decorate $args }

{{- if .useBitwarden }}
# Bitwarden helper functions
function Get-BitwardenSecret {
    param (
        [Parameter(Mandatory=$true)]
        [string]$ItemName,

        [Parameter(Mandatory=$false)]
        [string]$FieldName
    )

    . "$env:USERPROFILE\.local\share\chezmoi\.chezmoitemplates\bitwarden\functions.ps1"
    return Get-BitwardenSecret -ItemName $ItemName -FieldName $FieldName
}

function Unlock-BitwardenVault {
    . "$env:USERPROFILE\.local\share\chezmoi\.chezmoitemplates\bitwarden\functions.ps1"
    $sessionKey = Initialize-BitwardenAuth
    if ($sessionKey) {
        Write-Host "Bitwarden vault unlocked successfully" -ForegroundColor Green
        return $sessionKey
    } else {
        Write-Host "Failed to unlock Bitwarden vault" -ForegroundColor Red
        return $null
    }
}

# Add Bitwarden tab completion
Register-ArgumentCompleter -CommandName Get-BitwardenSecret -ParameterName ItemName -ScriptBlock {
    param($commandName, $parameterName, $wordToComplete, $commandAst, $fakeBoundParameters)

    $sessionKey = Initialize-BitwardenAuth
    if ($sessionKey) {
        $env:BW_SESSION = $sessionKey
        try {
            $items = bw list items | ConvertFrom-Json
            $env:BW_SESSION = $null

            $items | Where-Object { $_.name -like "$wordToComplete*" } | ForEach-Object {
                [System.Management.Automation.CompletionResult]::new(
                    $_.name,
                    $_.name,
                    'ParameterValue',
                    $_.name
                )
            }
        } catch {
            $env:BW_SESSION = $null
            return @()
        }
    } else {
        return @()
    }
}
{{- end }}

# Environment variables
$env:EDITOR = "nvim"
$env:VISUAL = "nvim"

{{- if .useBitwarden }}
# Load environment variables from Bitwarden
function Load-BitwardenEnvironmentVariables {
    . "$env:USERPROFILE\.local\share\chezmoi\.chezmoitemplates\bitwarden\functions.ps1"
    $envVars = Get-BitwardenEnvironmentVariables

    if ($envVars -and $envVars.Count -gt 0) {
        foreach ($variable in $envVars) {
            $variableName = $variable.Name
            $variableValue = $variable.Value

            # Handle absolute paths vs relative paths
            if ([System.IO.Path]::IsPathRooted($variableValue)) {
                $env:$variableName = $variableValue
            } else {
                $env:$variableName = [System.IO.Path]::Combine($env:USERPROFILE, $variableValue)
            }

            Write-Host "Set environment variable: $variableName" -ForegroundColor DarkGray
        }
    }
}

# Uncomment to load environment variables from Bitwarden on startup
# Load-BitwardenEnvironmentVariables
{{- end }}

# Welcome message
function Show-Welcome {
    Write-Host ""
    Write-Host "Welcome to PowerShell!" -ForegroundColor Blue
    Write-Host "Current time: $(Get-Date)" -ForegroundColor DarkGray
    Write-Host "PowerShell version: $($PSVersionTable.PSVersion)" -ForegroundColor DarkGray
    Write-Host ""
}

Show-Welcome
