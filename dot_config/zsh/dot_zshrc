_load_completions() {
  # fpath additions before compinit scans
  for sf_completions in {$XDG_CACHE_HOME,~/Library/Caches}/sf/autocomplete/functions/zsh(N/); do
    fpath=($sf_completions $fpath)
    break
  done

  zicompinit; zicdreplay

  # eval/compdef-based completions register after compinit
  (( ${+commands[zmx]} )) && eval "$(zmx completions zsh)"
  [[ -f $XDG_CONFIG_HOME/claude/hooks/peon-ping/completions.bash ]] && source $XDG_CONFIG_HOME/claude/hooks/peon-ping/completions.bash
  (( ${+commands[op]} )) && eval "$(op completion zsh)" && compdef _op op
  (( ${+commands[opencode]} )) && eval "$(opencode completion)"

  if (( ${+commands[brew]} )); then
    _pi() { words=(brew install "${(@)words[2,-1]}"); ((CURRENT+=1)); _brew }
    _pu() { words=(brew uninstall "${(@)words[2,-1]}"); ((CURRENT+=1)); _brew }
    _brew_list_wrapper() { words=(brew list "${(@)words[2,-1]}"); ((CURRENT+=1)); _brew }
    _brew_info_wrapper() { words=(brew info "${(@)words[2,-1]}"); ((CURRENT+=1)); _brew }
    compdef _pi pi
    compdef _pu pu
    compdef _brew_list_wrapper list
    compdef _brew_list_wrapper files
    compdef _brew_info_wrapper info
  fi

  if (( ${+commands[paru]} )); then
    _pi() { service=paru; words=(paru -S "${(@)words[2,-1]}"); ((CURRENT+=1)); _paru }
    _pu() { service=paru; words=(paru -Rn "${(@)words[2,-1]}"); ((CURRENT+=1)); _paru }
    _paru_query_wrapper() { service=paru; words=(paru -Q "${(@)words[2,-1]}"); ((CURRENT+=1)); _paru }
    _paru_info_wrapper() { service=paru; words=(paru -Si "${(@)words[2,-1]}"); ((CURRENT+=1)); _paru }
    _paru_files_wrapper() { service=paru; words=(paru -Ql "${(@)words[2,-1]}"); ((CURRENT+=1)); _paru }
    compdef _pi pi
    compdef _pu pu
    compdef _paru_query_wrapper list
    compdef _paru_files_wrapper files
    compdef _paru_info_wrapper info
  fi
}

