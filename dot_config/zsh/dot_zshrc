fzf-atuin-history-widget() {
  local selected num
  setopt localoptions noglobsubst noposixbuiltins pipefail no_aliases 2>/dev/null
  selected=$(atuin search --cmd-only --limit ${ATUIN_LIMIT:-5000} | tac |
    FZF_DEFAULT_OPTS="--height ${FZF_TMUX_HEIGHT:-40%} $FZF_DEFAULT_OPTS -n2..,.. --tiebreak=index --bind=ctrl-r:toggle-sort,ctrl-z:ignore $FZF_CTRL_R_OPTS --query=${LBUFFER} +m" fzf)
  local ret=$?
  if [[ -n $selected ]]; then
    LBUFFER+="${selected}"
  fi
  zle reset-prompt
  return $ret
}
zle -N fzf-atuin-history-widget
bindkey '^R' fzf-atuin-history-widget
FZF_CTRL_R_COMMAND= source <(fzf --zsh)

_load_completions() {
  # fpath additions before compinit scans
  for sf_completions in {$XDG_CACHE_HOME,~/Library/Caches}/sf/autocomplete/functions/zsh(N/); do
    fpath=($sf_completions $fpath)
    break
  done

  zicompinit; zicdreplay

  # eval/compdef-based completions register after compinit
  (( ${+commands[zmx]} )) && eval "$(zmx completions zsh)"
  [[ -f $XDG_CONFIG_HOME/claude/hooks/peon-ping/completions.bash ]] && source $XDG_CONFIG_HOME/claude/hooks/peon-ping/completions.bash
  (( ${+commands[op]} )) && eval "$(op completion zsh)" && compdef _op op
  (( ${+commands[opencode]} )) && eval "$(opencode completion)"

  if (( ${+commands[brew]} )); then
    _bi() { words=(brew install "${(@)words[2,-1]}"); ((CURRENT+=1)); _brew }
    _bu() { words=(brew uninstall "${(@)words[2,-1]}"); ((CURRENT+=1)); _brew }
    _brew_list_wrapper() { words=(brew list "${(@)words[2,-1]}"); ((CURRENT+=1)); _brew }
    _brew_info_wrapper() { words=(brew info "${(@)words[2,-1]}"); ((CURRENT+=1)); _brew }
    compdef _bi bi
    compdef _bu bu
    compdef _brew_list_wrapper list
    compdef _brew_list_wrapper files
    compdef _brew_info_wrapper info
  fi

  if (( ${+commands[yay]} )); then
    _yi() { service=yay; words=(yay -S "${(@)words[2,-1]}"); ((CURRENT+=1)); _yay }
    _yu() { service=yay; words=(yay -Rn "${(@)words[2,-1]}"); ((CURRENT+=1)); _yay }
    _yay_query_wrapper() { service=yay; words=(yay -Q "${(@)words[2,-1]}"); ((CURRENT+=1)); _yay }
    _yay_info_wrapper() { service=yay; words=(yay -Si "${(@)words[2,-1]}"); ((CURRENT+=1)); _yay }
    _yay_files_wrapper() { service=yay; words=(yay -Ql "${(@)words[2,-1]}"); ((CURRENT+=1)); _yay }
    compdef _yi yi
    compdef _yu yu
    compdef _yay_query_wrapper list
    compdef _yay_files_wrapper files
    compdef _yay_info_wrapper info
  fi
}

