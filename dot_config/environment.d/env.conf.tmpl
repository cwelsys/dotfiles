{{- if eq .chezmoi.os "darwin" }}
VSCODE_CLI_DATA_DIR=${HOME}/Applications/Code/code-portable-data/cli
XDG_CONFIG_HOME=${HOME}/.config
XDG_CACHE_HOME=${HOME}/.cache
XDG_DATA_HOME=${HOME}/.local/share
XDG_STATE_HOME=${HOME}/.local/state
XDG_BIN_HOME=${HOME}/.local/bin
XDG_PROJECTS_DIR=${HOME}/src
XDG_RUNTIME_DIR="${TMPDIR}"
{{- else if and (eq .chezmoi.os "linux") (not .isVM) (not .headless) }}
VSCODE_CLI_DATA_DIR=/opt/visual-studio-code/data/cli
ANDROID_HOME=${XDG_DATA_HOME}/android
WINEPREFIX=${XDG_DATA_HOME}/wine
MESA_VK_IGNORE_CONFORMANCE_WARNING=true
XDG_SESSION_TYPE=wayland
GDK_BACKEND=wayland,x11,*
SDL_VIDEODRIVER=wayland,x11
QT_QPA_PLATFORM=wayland;xcb
QT_QPA_PLATFORMTHEME=gtk3
ELECTRON_OZONE_PLATFORM_HINT=auto
MOZ_ENABLE_WAYLAND=1
_JAVA_AWT_WM_NONREPARENTING=1
SSH_AUTH_SOCK=${XDG_RUNTIME_DIR}/ssh-agent.socket
XCURSOR_SIZE=24
{{- end }}
GNUPGHOME=${XDG_DATA_HOME}/gnupg
DOCKER_CONFIG=${XDG_CONFIG_HOME}/docker
WGETRC=${XDG_CONFIG_HOME}/wget/wgetrc
WAKATIME_HOME=${XDG_CONFIG_HOME}/wakatime
TERMINAL=kitty
