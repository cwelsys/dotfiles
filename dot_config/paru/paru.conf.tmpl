#
# $PARU_CONF
# /etc/paru.conf
# ~/.config/paru/paru.conf
#
# See the paru.conf(5) manpage for options

[options]
PgpFetch
Devel
Provides
DevelSuffixes = -git -cvs -svn -bzr -darcs -always -hg -fossil
CloneDir = {{ .chezmoi.homeDir }}/.cache/aur
#AurOnly
BottomUp
SudoLoop
#UseAsk
#SaveChanges
BatchInstall
CombinedUpgrade
#CleanAfter
UpgradeMenu
#NewsOnUpgrade
#KeepSrc
#FailFast
NoCheck
SkipReview

#LocalRepo
#Chroot
#Sign
#SignDb
#KeepRepoCache


[bin]
FileManager = yazi
#MFlags = --skippgpcheck
#Sudo = doas
#Pager = Command



