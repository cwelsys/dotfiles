#!/bin/bash

[[ -f ~/.config/user-dirs.dirs ]] && source ~/.config/user-dirs.dirs
OUTPUT_DIR="${XDG_VIDEOS_DIR:-$HOME/Videos}/recordings"
mkdir -p "$OUTPUT_DIR"

PIDFILE="/tmp/screenrecord.pid"
OUTFILE="/tmp/screenrecord.out"
STARTFILE="/tmp/screenrecord.start"

MODE="gif"
for arg in "$@"; do
  case "$arg" in
    --video) MODE="video" ;;
    --gif) MODE="gif" ;;
  esac
done

stop_recording() {
  local pid
  pid=$(<"$PIDFILE")
  rm -f "$PIDFILE" "$STARTFILE"

  kill -INT "$pid" 2>/dev/null

  local count=0
  while kill -0 "$pid" 2>/dev/null && [ $count -lt 100 ]; do
    sleep 0.1
    count=$((count + 1))
  done

  if kill -0 "$pid" 2>/dev/null; then
    kill -9 "$pid" 2>/dev/null
    rm -f "$OUTFILE"
    return
  fi

  local output
  output=$(<"$OUTFILE")
  rm -f "$OUTFILE"

  if [[ -n "$output" && -s "$output" ]]; then
    clipboard-multi "$output"
  fi
}

start_recording() {
  local state_file="${XDG_CACHE_HOME:-$HOME/.cache}/dms/screenshot-state.json"

  dms screenshot --stdout --no-clipboard --no-notify >/dev/null || exit 0

  local geom
  geom=$(jq -r '.last_region | "\(.width)x\(.height)+\(.x)+\(.y)"' "$state_file") || exit 1

  local timestamp
  timestamp=$(date +'%m.%d_%H.%M.%S')

  if [[ "$MODE" == "video" ]]; then
    local output="$OUTPUT_DIR/$timestamp.mp4"
    echo "$output" > "$OUTFILE"

    gpu-screen-recorder -w region -region "$geom" -f 60 -k h264 -q very_high \
      -ac opus -a default_output -cursor yes -o "$output" &
  else
    local output="$OUTPUT_DIR/$timestamp.gif"
    echo "$output" > "$OUTFILE"

    wlgif -g "$geom" -d 0 -o "$output" &
  fi

  local pid=$!

  sleep 0.5
  if ! kill -0 "$pid" 2>/dev/null; then
    rm -f "$OUTFILE"
    exit 1
  fi

  echo "$pid" > "$PIDFILE"
  date +%s > "$STARTFILE"
}

if [[ -f "$PIDFILE" ]] && kill -0 "$(<"$PIDFILE")" 2>/dev/null; then
  stop_recording
else
  rm -f "$PIDFILE" "$STARTFILE"
  start_recording
fi
