#!/bin/bash

set -eo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
DIM='\033[2m'
BOLD='\033[1m'
RESET='\033[0m'

log_info()    { echo -e "${CYAN}→${RESET} $1"; }
log_success() { echo -e "${GREEN}✓${RESET} $1"; }
log_error()   { echo -e "${RED}✗${RESET} $1" >&2; }
log_warn()    { echo -e "${YELLOW}!${RESET} $1"; }

OS=$(uname -s | tr '[:upper:]' '[:lower:]')
HOSTNAME=$(hostname)
[[ "$OS" == "darwin" ]] && HOSTNAME="${HOSTNAME%.local}"

if [[ -n "${DOTS:-}" ]]; then
  YAML_FILE="$DOTS/.chezmoidata/pkgs.yml"
else
  YAML_FILE="$HOME/.local/share/chezmoi/.chezmoidata/pkgs.yml"
fi

# --- Section registry ---

declare -A SECTION_ICON=(
  [pacman]="👾" [brews]="🍺" [casks]="🍺" [dnf]="🎩"
  [cargo]="🦀" [npm]="📦" [go]="🐹" [pipx]="🐍" [yazi]="🦆"
)

declare -A SECTION_LABEL=(
  [pacman]="pacman" [brews]="brew" [casks]="cask" [dnf]="dnf"
  [cargo]="cargo" [npm]="npm" [go]="go" [pipx]="pipx" [yazi]="yazi"
)

# Sections that default to global scope (shared across all machines)
declare -A SECTION_GLOBAL=([yazi]=1)

section_icon()  { echo "${SECTION_ICON[$1]:-✓}"; }
section_label() { echo "${SECTION_LABEL[$1]:-$1}"; }
is_global()     { [[ -n "${SECTION_GLOBAL[$1]:-}" ]]; }

# --- Section discovery ---

system_sections() {
  case "$OS" in
    darwin) echo "brews casks" ;;
    linux)
      if [[ -f /etc/arch-release ]]; then echo "pacman"
      elif [[ -f /etc/fedora-release ]]; then echo "dnf"
      fi ;;
  esac
}

universal_sections() {
  local sections=""
  command -v cargo &>/dev/null && sections+="cargo "
  command -v npm &>/dev/null && sections+="npm "
  command -v pipx &>/dev/null && sections+="pipx "
  command -v ya &>/dev/null && sections+="yazi "
  echo "$sections"
}

all_sections() { echo "$(system_sections) $(universal_sections)"; }

# --- YAML helpers ---

yq_path() { yq "$1" "$YAML_FILE"; }
yq_global() { yq ".pkgs.global$1" "$YAML_FILE"; }
yq_host() { yq ".pkgs.hosts.$1$2" "$YAML_FILE"; }

host_exists() {
  local result
  result=$(yq_host "$1" "" 2>/dev/null)
  [[ -n "$result" && "$result" != "null" ]]
}

# Effective packages = global + host merged
manifest_packages() {
  local host="$1" section="$2"
  {
    yq_global ".$section[]" 2>/dev/null
    yq_host "$host" ".$section[]" 2>/dev/null
  } | sort -u
}

# --- Package detection ---

installed_packages() {
  local section="$1"
  case "$section" in
    brews)  brew leaves | sort ;;
    casks)  brew list --cask | sort ;;
    pacman) pacman -Qe | awk '{print $1}' | sort ;;
    dnf)    dnf repoquery --userinstalled --qf '%{name}' | sort | uniq ;;
    cargo)  cargo install --list 2>/dev/null | grep -E '^\w' | awk '{print $1}' | sort ;;
    npm)    npm list -g --depth=0 --json 2>/dev/null | jq -r '.dependencies // {} | keys[]' | sort ;;
    pipx)   pipx list --short 2>/dev/null | awk '{print $1}' | sort ;;
    go)
      local gobin="${GOBIN:-$HOME/go/bin}"
      for bin in "$gobin"/*; do
        [[ -x "$bin" ]] || continue
        go version -m "$bin" 2>/dev/null | grep -P '^\tpath\t' | cut -f3
      done | sort
      ;;
    yazi)   ya pkg list 2>/dev/null | awk '/^\t/{print $1}' | sort ;;
  esac
}

install_packages() {
  local section="$1"
  shift
  case "$section" in
    brews)  brew install "$@" ;;
    casks)  brew install --cask "$@" ;;
    pacman) yay -S --needed --noconfirm "$@" ;;
    dnf)    sudo dnf install -y "$@" ;;
    cargo)  for p in "$@"; do cargo install "$p"; done ;;
    npm)    npm install -g "$@" ;;
    pipx)   for p in "$@"; do pipx install "$p"; done ;;
    go)     for p in "$@"; do go install "${p}@latest"; done ;;
    yazi)   for p in "$@"; do ya pkg add "$p"; done ;;
  esac
}

# --- Commands ---

cmd_list() {
  local global_sections
  global_sections=$(yq_global "" 2>/dev/null)
  if [[ -n "$global_sections" && "$global_sections" != "null" ]]; then
    echo -e "${BOLD}Global packages:${RESET}"
    local sections
    sections=$(yq_global " | keys | .[]" 2>/dev/null)
    while IFS= read -r section; do
      local n icon label
      n=$(yq_global ".$section | length" 2>/dev/null)
      icon=$(section_icon "$section")
      label=$(section_label "$section")
      echo -e "  ${icon} ${label}: ${YELLOW}${n} pkgs${RESET}"
    done <<< "$sections"
    echo ""
  fi

  echo -e "${BOLD}Hosts:${RESET}"
  echo ""
  local hosts
  hosts=$(yq '.pkgs.hosts | keys | .[]' "$YAML_FILE")

  while IFS= read -r host; do
    local sections count=0 types=""
    sections=$(yq_host "$host" " | keys | .[]" 2>/dev/null)

    while IFS= read -r section; do
      local n
      n=$(yq_host "$host" ".$section | length" 2>/dev/null)
      count=$((count + n))
      types+="$(section_icon "$section") "
    done <<< "$sections"

    local marker=""
    [[ "$host" == "$HOSTNAME" ]] && marker=" ${GREEN}(current)${RESET}"

    printf "  ${CYAN}%-20s${RESET} ${DIM}%s${RESET} ${YELLOW}%d pkgs${RESET}%b\n" \
      "$host" "$types" "$count" "$marker"
  done <<< "$hosts"
}

cmd_show() {
  local target="$1"
  if ! host_exists "$target"; then
    log_error "Host '$target' not found"
    return 1
  fi

  echo -e "${BOLD}Packages for $target:${RESET}"

  # Show global sections that apply
  local global_sections
  global_sections=$(yq_global " | keys | .[]" 2>/dev/null)
  if [[ -n "$global_sections" && "$global_sections" != "null" ]]; then
    while IFS= read -r section; do
      local icon label
      icon=$(section_icon "$section")
      label=$(section_label "$section")
      echo -e "\n  ${icon} ${GREEN}${label}${RESET} ${DIM}(global):${RESET}"
      yq_global ".$section[]" 2>/dev/null | sed 's/^/    /'
    done <<< "$global_sections"
  fi

  # Show host-specific sections
  local host_sections
  host_sections=$(yq_host "$target" " | keys | .[]" 2>/dev/null)
  while IFS= read -r section; do
    local icon label
    icon=$(section_icon "$section")
    label=$(section_label "$section")
    echo -e "\n  ${icon} ${GREEN}${label}:${RESET}"
    yq_host "$target" ".$section[]" 2>/dev/null | sed 's/^/    /'
  done <<< "$host_sections"
}

cmd_clone() {
  local target="$1"
  if ! host_exists "$target"; then
    log_error "Host '$target' not found"
    return 1
  fi

  log_info "Cloning packages from $target"

  # Install global packages
  local global_sections
  global_sections=$(yq_global " | keys | .[]" 2>/dev/null)
  if [[ -n "$global_sections" && "$global_sections" != "null" ]]; then
    while IFS= read -r section; do
      local pkgs icon label
      mapfile -t pkgs < <(yq_global ".$section[]" 2>/dev/null)
      [[ ${#pkgs[@]} -eq 0 ]] && continue
      icon=$(section_icon "$section")
      label=$(section_label "$section")
      echo -e "${icon} Installing ${#pkgs[@]} global ${label} packages..."
      install_packages "$section" "${pkgs[@]}"
    done <<< "$global_sections"
  fi

  # Install host-specific packages
  local sections
  sections=$(yq_host "$target" " | keys | .[]" 2>/dev/null)
  while IFS= read -r section; do
    local pkgs icon label
    mapfile -t pkgs < <(yq_host "$target" ".$section[]" 2>/dev/null)
    [[ ${#pkgs[@]} -eq 0 ]] && continue
    icon=$(section_icon "$section")
    label=$(section_label "$section")
    echo -e "${icon} Installing ${#pkgs[@]} ${label} packages..."
    install_packages "$section" "${pkgs[@]}"
  done <<< "$sections"

  log_success "Clone complete. Run 'cmpack' to register this host."
}

cmd_diff() {
  local target="$1"
  if ! host_exists "$target"; then
    log_error "Host '$target' not found"
    return 1
  fi

  echo -e "${BOLD}$HOSTNAME vs $target:${RESET}"
  local sections
  sections=$(all_sections)

  for section in $sections; do
    local mine theirs icon label
    mine=$(manifest_packages "$HOSTNAME" "$section")
    theirs=$(manifest_packages "$target" "$section")
    [[ -z "$mine" && -z "$theirs" ]] && continue

    local only_mine only_theirs
    only_mine=$(comm -23 <(echo "$mine") <(echo "$theirs"))
    only_theirs=$(comm -13 <(echo "$mine") <(echo "$theirs"))

    if [[ -n "$only_mine" || -n "$only_theirs" ]]; then
      icon=$(section_icon "$section")
      label=$(section_label "$section")
      echo -e "\n  ${icon} ${BOLD}${label}:${RESET}"
      [[ -n "$only_mine" ]] && while IFS= read -r p; do echo -e "    ${GREEN}+ $p${RESET}"; done <<< "$only_mine"
      [[ -n "$only_theirs" ]] && while IFS= read -r p; do echo -e "    ${RED}- $p${RESET}"; done <<< "$only_theirs"
    fi
  done
}

cmd_init() {
  local target="$1"
  if host_exists "$HOSTNAME"; then
    log_error "Host '$HOSTNAME' already exists in manifest"
    return 1
  fi
  if ! host_exists "$target"; then
    log_error "Template host '$target' not found"
    return 1
  fi

  log_info "Initializing $HOSTNAME from $target"
  yq -i ".pkgs.hosts.$HOSTNAME = .pkgs.hosts.$target" "$YAML_FILE"
  log_success "Created $HOSTNAME entry (copied from $target)"
}

ensure_brew_in_path() {
  if ! command -v brew &>/dev/null; then
    if [[ -x "/opt/homebrew/bin/brew" ]]; then
      log_warn "Homebrew not in PATH. Run: eval \"\$(/opt/homebrew/bin/brew shellenv)\""
    elif [[ -x "/usr/local/bin/brew" ]]; then
      log_warn "Homebrew not in PATH. Run: eval \"\$(/usr/local/bin/brew shellenv)\""
    else
      log_error "Homebrew not installed"
    fi
    exit 1
  fi
}

# --- Sync ---

sync_section() {
  local section="$1" scope="$2"
  local icon label yq_prefix
  icon=$(section_icon "$section")
  label=$(section_label "$section")

  if [[ "$scope" == "global" ]]; then
    yq_prefix=".pkgs.global"
  else
    yq_prefix=".pkgs.hosts.$HOSTNAME"
  fi

  log_info "Checking $label..."
  local installed manifest new_pkgs removed_pkgs
  installed=$(installed_packages "$section")
  manifest=$(manifest_packages "$HOSTNAME" "$section")

  new_pkgs=$(comm -23 <(echo "$installed") <(echo "$manifest"))
  removed_pkgs=$(comm -13 <(echo "$installed") <(echo "$manifest"))

  local changed=false

  if [[ -n "$new_pkgs" ]]; then
    changed=true
    local count
    count=$(echo "$new_pkgs" | wc -l)
    local scope_tag=""
    [[ "$scope" == "global" ]] && scope_tag=" ${DIM}(global)${RESET}"
    echo -e "${icon} ${count} new ${label} packages${scope_tag}"
    while IFS= read -r p; do echo -e "  ${GREEN}+${RESET} $p"; done <<< "$new_pkgs"

    local json_array
    json_array=$(echo "$new_pkgs" | jq -R . | jq -s .)
    yq -i "${yq_prefix}.$section += $json_array" "$YAML_FILE"
  fi

  if [[ -n "$removed_pkgs" ]]; then
    changed=true
    local count
    count=$(echo "$removed_pkgs" | wc -l)
    local scope_tag=""
    [[ "$scope" == "global" ]] && scope_tag=" ${DIM}(global)${RESET}"
    echo -e "${icon} ${count} removed ${label} packages${scope_tag}"
    while IFS= read -r p; do echo -e "  ${RED}-${RESET} $p"; done <<< "$removed_pkgs"

    while IFS= read -r pkg; do
      yq -i "del(${yq_prefix}.$section[] | select(. == \"$pkg\"))" "$YAML_FILE"
    done <<< "$removed_pkgs"
  fi

  if [[ "$changed" == true ]]; then
    yq -i "(${yq_prefix}.$section | select(. != null)) |= sort" "$YAML_FILE"
  fi

  [[ "$changed" == true ]]
}

cmd_sync() {
  [[ "$(system_sections)" == *brew* ]] && ensure_brew_in_path

  if [[ ! -f "$YAML_FILE" ]]; then
    log_error "Manifest not found: $YAML_FILE"
    exit 1
  fi

  local backup_dir="$HOME/.config/chezmoi/backups"
  mkdir -p "$backup_dir"
  cp "$YAML_FILE" "$backup_dir/pkgs.yml.bak.$(date +%Y%m%d-%H%M%S)"
  ls -1t "$backup_dir"/pkgs.yml.bak.* 2>/dev/null | tail -n +11 | xargs -r rm -f

  local _host_exists=false
  host_exists "$HOSTNAME" && _host_exists=true

  local has_changes=false
  local sections
  sections=$(all_sections)

  for section in $sections; do
    local scope="host"
    is_global "$section" && scope="global"

    # For host-scoped sections on a new host, create the entry first
    if [[ "$scope" == "host" && "$_host_exists" == false ]]; then
      _host_exists=true
    fi

    if sync_section "$section" "$scope"; then
      has_changes=true
    fi
  done

  if [[ "$has_changes" == false ]]; then
    log_success "Up to date"
  fi
}

# --- Main ---

usage() {
  cat <<EOF
$(echo -e "${BOLD}cmpack${RESET} - chezmoi package manifest sync")

$(echo -e "${BOLD}Usage:${RESET}")
  cmpack                          Sync installed packages with manifest
  cmpack -l, --list               List configured hosts
  cmpack -s, --show HOST          Show packages for a host
  cmpack -c, --clone HOST         Install packages from another host
  cmpack -d, --diff HOST          Compare current host with another
  cmpack -i, --init HOST          Create current host entry from template
EOF
  exit 0
}

MODE="sync"
TARGET_HOST=""

while [[ $# -gt 0 ]]; do
  case $1 in
    -l|--list)  MODE="list"; shift ;;
    -s|--show)  MODE="show"; TARGET_HOST="$2"; shift 2 ;;
    -c|--clone) MODE="clone"; TARGET_HOST="$2"; shift 2 ;;
    -d|--diff)  MODE="diff"; TARGET_HOST="$2"; shift 2 ;;
    -i|--init)  MODE="init"; TARGET_HOST="$2"; shift 2 ;;
    -h|--help)  usage ;;
    *)          log_error "Unknown option: $1"; usage ;;
  esac
done

if [[ "$MODE" =~ ^(show|clone|diff|init)$ && -z "$TARGET_HOST" ]]; then
  log_error "--${MODE} requires a hostname"
  usage
fi

case "$MODE" in
  list)  cmd_list ;;
  show)  cmd_show "$TARGET_HOST" ;;
  clone) cmd_clone "$TARGET_HOST" ;;
  diff)  cmd_diff "$TARGET_HOST" ;;
  init)  cmd_init "$TARGET_HOST" ;;
  sync)  cmd_sync ;;
esac
