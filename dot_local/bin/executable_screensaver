#!/bin/bash

if [[ "$1" == "--run" ]]; then
  trap 'kill %1 2>/dev/null; exit 0' INT TERM HUP
  stty -echo 2>/dev/null
  printf '\e[?1003h'

  while true; do
    tte -i ~/Pictures/screensaver.txt \
      --frame-rate 60 \
      --canvas-width 0 --canvas-height 0 \
      --reuse-canvas --anchor-canvas c --anchor-text c \
      --random-effect --exclude-effects matrix synthgrid sweep \
      --no-eol --no-restore-cursor &

    while kill -0 %1 2>/dev/null; do
      read -t 0.2 -n 1 -s && kill %1 2>/dev/null && exit 0
    done
  done
fi

command -v tte &>/dev/null || exit 1
pgrep -f "app-id=screensaver" >/dev/null && exit 0

exec kitten panel \
  --edge=center \
  --layer=overlay \
  --focus-policy=exclusive \
  --grab-keyboard \
  --exclusive-zone=-1 \
  --app-id=screensaver \
  -o background=#000000 \
  -o background_opacity=1 \
  -o tab_bar_style=hidden \
  -o cursor_blink_interval=0 \
  -o enable_audio_bell=no \
  screensaver --run
