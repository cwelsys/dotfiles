#!/usr/bin/env zsh

has_cmd() {
  for opt in "$@"; do
    (( $+commands[$opt] )) || return 1
  done
  return 0
}

# preview dimensions for image rendering
dim=${FZF_PREVIEW_COLUMNS}x${FZF_PREVIEW_LINES}
if [[ $dim = x ]]; then
  dim=$(stty size < /dev/tty | awk '{print $2 "x" $1}')
elif ! [[ $KITTY_WINDOW_ID ]] && (( FZF_PREVIEW_TOP + FZF_PREVIEW_LINES == $(stty size < /dev/tty | awk '{print $1}') )); then
  dim=${FZF_PREVIEW_COLUMNS}x$((FZF_PREVIEW_LINES - 1))
fi

mime=$(file -Lbs --mime-type "$1")
category=${mime%%/*}
kind=${mime##*/}
ext=${1##*.}

if [[ -d "$1" || -L "$1" && -d "$1" ]]; then
  if has_cmd eza; then
    eza -1 --git --color=always --icons "$1"
  fi
elif [ "$kind" = json ]; then
  if has_cmd jupyter bat && [ "$ext" = ipynb ]; then
    jupyter nbconvert --to python --stdout "$1" | bat --color=always -plpython
  elif has_cmd jq; then
    jq -Cr . "$1"
  fi
elif [ "$kind" = vnd.sqlite3 ]; then
  if has_cmd yes sqlite3 bat; then
    yes .q | sqlite3 "$1" | bat --color=always -plsql
  fi
elif [ "$kind" = pdf ]; then
  if has_cmd timg kitty; then
    timg -p kitty --clear --frames=1 --threads=12 -Ug "$dim" "$1"
  elif has_cmd timg; then
    timg -p i --frames=1 --threads=12 -Ug "$dim" "$1"
  elif has_cmd pdftotext sed; then
    pdftotext -q "$1" - | sed "s/\f/$(printf '%*s' "${FZF_PREVIEW_COLUMNS:-80}" '' | tr ' ' '─')\\n/g"
  fi
elif [ "$kind" = rfc822 ]; then
  if has_cmd bat; then
    bat --color=always -lEmail "$1"
  fi
elif [ "$category" = image ]; then
  if has_cmd kitty; then
    kitten icat --clear --transfer-mode=memory --unicode-placeholder --stdin=no --place="$dim@0x0" "$1" | sed '$d' | sed $'$s/$/\e[m/'
  elif has_cmd timg; then
    timg -p i -IU --threads=12 -g "$dim" "$1"
  elif has_cmd chafa; then
    chafa -f symbols "$1"
  fi
  if has_cmd exiftool; then
    exiftool "$1" | bat --color=always -plyaml
  fi
elif [ "$category" = text ]; then
  if [[ "$1" == *.md ]] && has_cmd mdcat; then
    mdcat -l "$1"
  elif has_cmd bat; then
    bat --color=always "$1"
  fi
elif [ "$kind" = vnd.openxmlformats-officedocument.spreadsheetml.sheet ] || [ "$kind" = vnd.ms-excel ]; then
  if has_cmd in2csv xsv bat; then
    in2csv "$1" | xsv table | bat -ltsv --color=always
  fi
else
  if has_cmd lesspipe.sh; then
    lesspipe.sh "$1" | bat --color=always
  else
    exit 1
  fi
fi
