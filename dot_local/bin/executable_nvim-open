#!/usr/bin/env python3

import glob
import json
import os
import shutil
import subprocess
import sys

RUNTIME = os.environ.get("XDG_RUNTIME_DIR", f"/run/user/{os.getuid()}")
KITTY_SOCKET_GLOB = "/tmp/mykitty-*"


def resolve(name, *fallbacks):
    found = shutil.which(name)
    if found:
        return found
    for f in fallbacks:
        if os.path.exists(f):
            return f
    return name  # last resort: let it fail loudly rather than silently


NVIM = resolve("nvim", "/usr/bin/nvim")
KITTEN = resolve("kitten", os.path.expanduser("~/.local/bin/kitten"))
KITTY = resolve("kitty", os.path.expanduser("~/.local/bin/kitty"))


def nvim_remote(server, files):
    if not files:
        return
    subprocess.run([NVIM, "--server", server, "--remote-silent", *files])


def _ppid_map():
    parents = {}
    for stat in glob.glob("/proc/[0-9]*/stat"):
        try:
            with open(stat) as f:
                data = f.read()
            pid = int(data.split(" ", 1)[0])
            # comm may contain spaces/parens; fields after the last ')' are
            #: state ppid pgrp ...
            after = data.rsplit(")", 1)[1].split()
            parents[pid] = int(after[1])
        except (OSError, ValueError, IndexError):
            continue
    return parents


def _descendants(pid, parents):
    children = {}
    for child, parent in parents.items():
        children.setdefault(parent, []).append(child)
    seen, stack = set(), [pid]
    while stack:
        for child in children.get(stack.pop(), []):
            if child not in seen:
                seen.add(child)
                stack.append(child)
    return seen


def server_for_pid(pid):
    for cand in [pid, *_descendants(pid, _ppid_map())]:
        matches = sorted(glob.glob(os.path.join(RUNTIME, f"nvim.{cand}.*")))
        if matches:
            return matches[0]
    return None


def kitty_sockets():
    socks = []
    cur = os.environ.get("KITTY_LISTEN_ON")
    if cur:
        socks.append(cur if cur.startswith("unix:") else "unix:" + cur)
    for path in sorted(glob.glob(KITTY_SOCKET_GLOB)):
        u = "unix:" + path
        if u not in socks:
            socks.append(u)
    return socks


def kitty_ls(sock):
    try:
        out = subprocess.run(
            [KITTEN, "@", "--to", sock, "ls"],
            capture_output=True,
            text=True,
            timeout=4,
        )
        if out.returncode == 0:
            return json.loads(out.stdout)
    except Exception:
        pass
    return None


def _iter_windows(data):
    for osw in data:
        for tab in osw.get("tabs", []):
            yield from tab.get("windows", [])


def find_nvim_windows():
    found = []
    for sock in kitty_sockets():
        data = kitty_ls(sock)
        if not data:
            continue
        for win in _iter_windows(data):
            for fp in win.get("foreground_processes", []):
                cmd = fp.get("cmdline") or []
                if cmd and os.path.basename(cmd[0]) == "nvim":
                    found.append(
                        {
                            "sock": sock,
                            "win_id": win["id"],
                            "pid": fp["pid"],
                            "last_focused_at": win.get("last_focused_at", 0),
                        }
                    )
                    break
    return found


def focus_kitty_window(sock, win_id):
    subprocess.run(
        [KITTEN, "@", "--to", sock, "focus-window", "--match", f"id:{win_id}"],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )


def newest_kitty():
    best_sock, best_recency = None, -1
    for sock in kitty_sockets():
        data = kitty_ls(sock)
        if not data:
            continue
        recency = max(
            (w.get("last_focused_at", 0) for w in _iter_windows(data)),
            default=0,
        )
        if recency > best_recency:
            best_sock, best_recency = sock, recency
    return best_sock


def main():
    files = [os.path.abspath(a) for a in sys.argv[1:]]
    server = os.environ.get("NVIM")
    if server:
        nvim_remote(server, files)
        return

    candidates = sorted(
        find_nvim_windows(), key=lambda c: c["last_focused_at"], reverse=True
    )

    for c in candidates:
        srv = server_for_pid(c["pid"])
        if srv and os.path.exists(srv):
            nvim_remote(srv, files)
            focus_kitty_window(c["sock"], c["win_id"])
            return

    sock = newest_kitty()
    if sock:
        cwd = os.path.dirname(files[0]) if files else os.path.expanduser("~")
        out = subprocess.run(
            [
                KITTEN,
                "@",
                "--to",
                sock,
                "launch",
                "--type=tab",
                f"--cwd={cwd}",
                "--",
                NVIM,
                "--",
                *files,
            ],
            capture_output=True,
            text=True,
        )
        win_id = out.stdout.strip()
        if win_id:
            focus_kitty_window(sock, win_id)
        return

    os.execv(KITTY, [KITTY, NVIM, "--", *files])


if __name__ == "__main__":
    main()
